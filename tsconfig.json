{
  "compilerOptions": {
    // Runtime and module settings shared by the library and Storybook.
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "useDefineForClassFields": true,

    // Keep transpilation compatible with bundlers and JSON imports.
    "esModuleInterop": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "types": ["vite/client"],

    // Local source alias used across the library and stories.
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@local/*": ["src/*"]
    },

    // Shared type safety defaults.
    "strict": true,
    "skipLibCheck": true,

    // `tsc` is used only as a type-check step in this repo.
    "noEmit": true
  }
}
