{
  "compilerOptions": {
    // Runtime and module settings for a browser React library built by Vite.
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "useDefineForClassFields": true,

    // Keep transpilation compatible with bundlers and JSON imports.
    "esModuleInterop": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "types": ["vite/client"],

    // Local source alias used across the library.
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@local/*": ["src/*"]
    },

    // Strong library-facing type safety.
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,

    // `tsc` is used here as a type-check step; declarations come from `vite-plugin-dts`.
    "noEmit": true
  },
  "include": ["src", "vite-env.d.ts", ".storybook-stories/**/*.ts", ".storybook-stories/**/*.tsx"],
  "exclude": ["build", "build-storybook", "node_modules"]
}
